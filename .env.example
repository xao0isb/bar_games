# Copy to .env and adjust:  cp .env.example .env

# ── Public address ──────────────────────────────────────────────────────────
# Domain for automatic HTTPS via Caddy. Point a real hostname at this server to
# get a free Let's Encrypt certificate automatically:
#   DOMAIN=game.example.com
# Leave as ":80" to serve plain HTTP (e.g. access by IP while you have no domain).
DOMAIN=:80

# ── QR / links ──────────────────────────────────────────────────────────────
# Usually leave empty — the QR link is derived from the incoming request. Set it
# only to force an exact public base URL (must match how players reach the site):
#   PUBLIC_BASE_URL=https://game.example.com
PUBLIC_BASE_URL=

# Optional Host allow-list (comma-separated). Empty = allow any host.
#   ALLOWED_HOSTS=game.example.com
ALLOWED_HOSTS=
